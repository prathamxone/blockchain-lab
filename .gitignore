# =============================================================================
# .gitignore — Blockchain Lab (IT Engg. SEM VIII, Mumbai University, AY 2025-26)
# Web3 Development: Hardhat | Truffle | Ganache | Foundry | Remix
# Covers: Windows + WSL / Linux environments
# =============================================================================

# -----------------------------------------------------------------------------
# Heavy Documents (PDFs, large binaries)
# -----------------------------------------------------------------------------
*.pdf
*.docx
*.pptx
*.xlsx

# -----------------------------------------------------------------------------
# Node.js / npm / yarn / pnpm
# -----------------------------------------------------------------------------
node_modules/
npm-debug.log*
yarn-debug.log*
yarn-error.log*
pnpm-debug.log*
.npm/
.yarn/
.pnp.*
.cache/

# -----------------------------------------------------------------------------
# Hardhat
# -----------------------------------------------------------------------------
artifacts/
cache/
typechain/
typechain-types/
coverage/
coverage.json
.hardhat-compile-cache/

# -----------------------------------------------------------------------------
# Truffle
# -----------------------------------------------------------------------------
build/contracts/
build/
.truffle_temp/

# -----------------------------------------------------------------------------
# Ganache
# -----------------------------------------------------------------------------
.ganache/
ganache.db
.db/

# -----------------------------------------------------------------------------
# Foundry (Exp-6 — dependencies installed by `forge install`)
# -----------------------------------------------------------------------------
out/
forge-cache/
broadcast/
Exp-6/lib/
.gas-snapshot

# -----------------------------------------------------------------------------
# Hardhat Ignition
# -----------------------------------------------------------------------------
ignition/deployments/
**/ignition/deployments/

# -----------------------------------------------------------------------------
# Remix IDE (Remixd local file access)
# -----------------------------------------------------------------------------
.remix/

# -----------------------------------------------------------------------------
# Environment / Secrets — NEVER commit private keys or API keys
# -----------------------------------------------------------------------------
.env
.env.*
!.env.example
*.pem
*.key
secrets.json
secret.json

# -----------------------------------------------------------------------------
# Compiled / Build Outputs
# -----------------------------------------------------------------------------
dist/
build/
*.js.map

# -----------------------------------------------------------------------------
# Logs
# -----------------------------------------------------------------------------
logs/
*.log

# -----------------------------------------------------------------------------
# OS-specific junk
# -----------------------------------------------------------------------------
# macOS
.DS_Store
.AppleDouble
.LSOverride

# Windows
Thumbs.db
ehthumbs.db
Desktop.ini
$RECYCLE.BIN/

# Linux
*~

# -----------------------------------------------------------------------------
# VS Code — keep extensions.json and tasks.json; ignore personal settings
# -----------------------------------------------------------------------------
.vscode/*
!.vscode/extensions.json
!.vscode/tasks.json
!.vscode/launch.json
!.vscode/settings.json.example

# -----------------------------------------------------------------------------
# Miscellaneous
# -----------------------------------------------------------------------------
*.orig
*.patch
*.rej
.hypothesis/
.pytest_cache/
__pycache__/
*.pyc
.blackboxcli/
*.temp/
TODO.md

# -----------------------------------------------------------------------------
# Remix IDE cache (generated by remixd / browser-based Remix)
# -----------------------------------------------------------------------------
.deps/

# -----------------------------------------------------------------------------
# Hyperledger Fabric — external tooling (must NOT be committed)
# fabric-samples is cloned separately at ~/fabric-samples — never inside the repo
# See EXP-5_PLAN.md §8 Security Reminders
# -----------------------------------------------------------------------------
fabric-samples/
myasset.tar.gz
*.tar.gz
