# DVote Frontend — Environment Variables Reference
# Copy to .env.local and fill in actual values.
# NEVER commit .env.local to version control (it is git-ignored by default).
#
# Vite only exposes variables prefixed with VITE_ to client code.
# Variables are accessed via import.meta.env.VITE_* (validated at startup in src/config/env.ts).

# ─── Backend API ──────────────────────────────────────────────────────────────
# Backend API base URL — WITHOUT trailing slash.
# The frontend API client appends /api/v1 automatically.
#
# Local dev (backend on 4000):
VITE_API_BASE_URL=http://localhost:4000
#
# Preview/production (set in your deployment .env or override in .env.local):
# VITE_API_BASE_URL=https://dvote-backend.vercel.app

# ─── WalletConnect Cloud ──────────────────────────────────────────────────────
# REQUIRED. WalletConnect Cloud project ID for WalletConnect v2 connector.
# Without this, WalletConnect (and mobile wallets) will not function.
# 1. Go to: https://cloud.walletconnect.com/
# 2. Create a new project (type: Web)
# 3. Copy the Project ID here
VITE_APP_WALLETCONNECT_PROJECT_ID=your_walletconnect_project_id_here

# ─── Chain Config ─────────────────────────────────────────────────────────────
# Target EVM chain ID. DVote MVP targets Sepolia testnet (11155111).
# Must match the backend CHAIN_ID environment variable.
# Changing this requires re-deploying contracts on the new chain.
VITE_CHAIN_ID=11155111

# ─── App Version ──────────────────────────────────────────────────────────────
# Application version — used as part of tutorial/onboarding persistence key.
# Format: semver string (e.g., 0.1.0, 1.0.0)
# Increment when tutorial state should be reset for all users.
VITE_APP_VERSION=0.1.0
