# DVote Frontend — Environment Variables
# Copy this file to .env.local and fill in actual values.
# NEVER commit .env.local to version control.

# ─── API ───────────────────────────────────────────────────────────────────────
# Backend API base URL.
# Dev default: http://localhost:4000
# For preview testing against deployed backend, override in .env.local:
#   VITE_API_BASE_URL=https://dvote-backend.vercel.app
VITE_API_BASE_URL=http://localhost:4000

# ─── WALLET CONNECT ────────────────────────────────────────────────────────────
# WalletConnect Cloud project ID. Required for WalletConnect connector.
# Obtain from: https://cloud.walletconnect.com/
VITE_APP_WALLETCONNECT_PROJECT_ID=your_walletconnect_project_id_here

# ─── CHAIN ─────────────────────────────────────────────────────────────────────
# Target network chain ID. DVote MVP targets Sepolia (11155111).
VITE_CHAIN_ID=11155111

# ─── APP ───────────────────────────────────────────────────────────────────────
# Application version — used as part of tutorial persistence key.
VITE_APP_VERSION=0.1.0
