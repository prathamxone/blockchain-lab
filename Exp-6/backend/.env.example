# Runtime
NODE_ENV=development
PORT=4000

# Secret generation helpers:
# - One-shot print: npm run env:secrets
# - Apply directly to backend/.env: npm run env:secrets:apply
# - OpenSSL fallback examples:
#   openssl rand -hex 32
#   openssl rand -base64 32

# API and CORS
API_BASE_PATH=/api/v1
FRONTEND_ORIGINS=http://localhost:5173,http://localhost:4173
CORS_ALLOW_CREDENTIALS=true

# Auth and session
JWT_ACCESS_SECRET=replace_with_access_secret
JWT_REFRESH_SECRET=replace_with_refresh_secret
JWT_ACCESS_TTL_SEC=900
JWT_REFRESH_TTL_SEC=604800
SESSION_IDLE_TIMEOUT_SEC=1800
CSRF_SECRET=replace_with_csrf_secret

# Internal protection
INTERNAL_API_KEY=replace_with_internal_api_key
CRON_SECRET=replace_with_cron_secret
READY_IP_ALLOWLIST=

# Role wallet bootstrap (optional but recommended)
ADMIN_WALLET=
ECI_WALLET=
SRO_WALLET=
RO_WALLET=
OBSERVER_WALLET=

# Turso (libSQL)
TURSO_DATABASE_URL=libsql://your-db-name.turso.io
TURSO_AUTH_TOKEN=replace_with_turso_token

# Upstash Redis
UPSTASH_REDIS_REST_URL=https://your-upstash-url.upstash.io
UPSTASH_REDIS_REST_TOKEN=replace_with_upstash_token

# Cloudflare R2 (S3-compatible)
R2_ACCOUNT_ID=replace_with_account_id
R2_BUCKET=replace_with_bucket
R2_ACCESS_KEY_ID=replace_with_access_key
R2_SECRET_ACCESS_KEY=replace_with_secret_access_key
R2_REGION=auto

# Encryption key ring (AES-GCM envelope) // Optional usage $(openssl rand -base64 32)
KYC_ENC_ACTIVE_KEY_VERSION=v1
KYC_ENC_KEY_V1_BASE64=replace_with_32byte_base64_key
KYC_ENC_KEY_V2_BASE64=
KYC_HASH_SALT=replace_with_strong_hash_salt

# Scanner adapter
SCAN_ADAPTER_ENABLED=true

# Blockchain provider (for mirror and relay)
CHAIN_ID=11155111
RPC_URL=replace_with_rpc_url

# Upload policy
UPLOAD_CONTRACT_TTL_SEC=600
UPLOAD_DOC_MAX_BYTES=10485760
UPLOAD_PROFILE_MAX_BYTES=5242880

# Vote policy
VOTE_TOKEN_TTL_SEC=60
VOTE_TIMEOUT_LOOKUP_WINDOW_SEC=120

# Smoke validation helpers
SMOKE_LOCAL_BASE_URL=http://localhost:4000
SMOKE_LOCAL_AUTH_BEARER=__MANUAL_LOCAL_ACCESS_TOKEN__
SMOKE_PREVIEW_BASE_URL=http://localhost:4000
SMOKE_PREVIEW_BEARER_TOKEN=__MANUAL_PREVIEW_BEARER_TOKEN__
SMOKE_PREVIEW_AUTH_BEARER=__MANUAL_PREVIEW_ACCESS_TOKEN__
