# DVote Backend — Environment Variables Reference
# Copy to .env (or .env.local) and fill in actual values.
# NEVER commit a file with real secrets to version control.
#
# Secret generation helpers (from backend dir):
#   npm run env:secrets            → prints new secrets to stdout
#   npm run env:secrets:apply      → applies secrets directly to backend/.env
#   openssl rand -hex 32           → manual 64-char hex secret
#   openssl rand -base64 32        → manual base64 secret

# ─── Runtime ──────────────────────────────────────────────────────────────────
NODE_ENV=development
PORT=4000

# ─── API and CORS ─────────────────────────────────────────────────────────────
# Comma-separated list of allowed frontend origins.
# Must include the exact origin where the Vite dev server runs.
# Default dev: http://localhost:5173, http://localhost:4173
API_BASE_PATH=/api/v1
FRONTEND_ORIGINS=http://localhost:5173,http://localhost:4173,http://127.0.0.1:5173
CORS_ALLOW_CREDENTIALS=true

# ─── Auth and Session ─────────────────────────────────────────────────────────
# REQUIRED. Minimum 32 hex characters (64 chars = 32 bytes).
JWT_ACCESS_SECRET=replace_with_64char_hex_secret
JWT_REFRESH_SECRET=replace_with_64char_hex_secret
JWT_ACCESS_TTL_SEC=900
JWT_REFRESH_TTL_SEC=604800
SESSION_IDLE_TIMEOUT_SEC=1800
# CSRF secret — used for HMAC validation of x-csrf-token header on refresh/logout.
CSRF_SECRET=replace_with_64char_hex_secret

# ─── Internal Protection ──────────────────────────────────────────────────────
# Used by internal/admin routes and cron jobs.
INTERNAL_API_KEY=replace_with_48char_hex_secret
CRON_SECRET=replace_with_48char_hex_secret
# Optional: comma-separated IP allowlist for /ready endpoint. Empty = allow all.
READY_IP_ALLOWLIST=

# ─── Role Wallet Bootstrap ────────────────────────────────────────────────────
# Wallet addresses for each role. Set at startup to seed DB role mappings.
# Changing after first seed requires re-seeding or manual DB update.
ADMIN_WALLET=0xyour_admin_wallet_address
ECI_WALLET=0xyour_eci_wallet_address
SRO_WALLET=0xyour_sro_wallet_address
RO_WALLET=0xyour_ro_wallet_address
OBSERVER_WALLET=0xyour_observer_wallet_address

# ─── Private Keys (OPTIONAL — Dev/Smoke Testing Only) ─────────────────────────
# NEVER use mainnet keys here. For local dev/smoke testing only.
# Used by scripts/smoke-local.mjs and access token generation scripts.
ADMIN_PRIVATE_KEY=
ECI_PRIVATE_KEY=
SRO_PRIVATE_KEY=
RO_PRIVATE_KEY=
OBSERVER_PRIVATE_KEY=

# ─── Turso (libSQL) ───────────────────────────────────────────────────────────
# REQUIRED. Get from: https://turso.tech/
TURSO_DATABASE_URL=libsql://your-db-name.turso.io
TURSO_AUTH_TOKEN=replace_with_turso_auth_token

# ─── Upstash Redis ────────────────────────────────────────────────────────────
# REQUIRED. Get from: https://upstash.com/
UPSTASH_REDIS_REST_URL=https://your-db.upstash.io
UPSTASH_REDIS_REST_TOKEN=replace_with_upstash_token

# ─── Cloudflare R2 (S3-compatible) ───────────────────────────────────────────
# REQUIRED for file uploads (KYC docs, profile photos, contracts).
# Get from: https://dash.cloudflare.com/ → R2 → Manage API Tokens
R2_ACCOUNT_ID=replace_with_cloudflare_account_id
R2_BUCKET=replace_with_r2_bucket_name
R2_ACCESS_KEY_ID=replace_with_r2_access_key_id
R2_SECRET_ACCESS_KEY=replace_with_r2_secret_access_key
R2_REGION=auto

# ─── KYC Encryption Key Ring (AES-GCM) ───────────────────────────────────────
# REQUIRED. Active key version controls which key is used for new encryptions.
# Retiring a key version means decryption of old data still works (read all versions).
# Generate: openssl rand -base64 32
KYC_ENC_ACTIVE_KEY_VERSION=v1
KYC_ENC_KEY_V1_BASE64=replace_with_32byte_base64_key
KYC_ENC_KEY_V2_BASE64=
# REQUIRED. Pepper for deterministic wallet hash (never changes after first use).
KYC_HASH_SALT=replace_with_48char_hex_salt

# ─── Scanner Adapter ──────────────────────────────────────────────────────────
# Set false to skip on-chain scan sync (useful for offline dev).
SCAN_ADAPTER_ENABLED=true

# ─── Blockchain Provider ──────────────────────────────────────────────────────
# REQUIRED. Must match the frontend's VITE_CHAIN_ID.
# DVote MVP targets Sepolia (11155111).
CHAIN_ID=11155111
# REQUIRED. RPC provider URL. Use Alchemy, Infura, or public RPC.
# Get Alchemy key: https://dashboard.alchemy.com/
RPC_URL=https://eth-sepolia.g.alchemy.com/v2/your_alchemy_api_key

# ─── Upload Policy ────────────────────────────────────────────────────────────
UPLOAD_CONTRACT_TTL_SEC=600
UPLOAD_DOC_MAX_BYTES=10485760
UPLOAD_PROFILE_MAX_BYTES=5242880

# ─── Vote Policy ──────────────────────────────────────────────────────────────
VOTE_TOKEN_TTL_SEC=60
VOTE_TIMEOUT_LOOKUP_WINDOW_SEC=120

# ─── Smoke Validation Helpers (Optional) ──────────────────────────────────────
# Used by scripts/smoke-local.mjs and scripts/smoke-preview.mjs.
# SMOKE_LOCAL_AUTH_BEARER must be a real JWT access token from /auth/verify.
# To generate a local token: node scripts/gen-local-token.mjs
SMOKE_LOCAL_BASE_URL=http://localhost:4000
SMOKE_LOCAL_AUTH_BEARER=__MANUAL_LOCAL_ACCESS_TOKEN__
SMOKE_PREVIEW_BASE_URL=https://your-preview-domain.vercel.app
# Preview Bearer: run scripts/gen-preview-token.mjs → saves to /tmp/dvote_preview_access_token.txt
SMOKE_PREVIEW_AUTH_BEARER=__MANUAL_PREVIEW_ACCESS_TOKEN__
