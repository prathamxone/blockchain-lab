{
  "name": "dvote-backend",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "description": "DVote MVP backend for Exp-6",
  "engines": {
    "node": ">=22.0.0"
  },
  "scripts": {
    "dev": "tsx watch src/server.ts",
    "build": "tsc -p tsconfig.json",
    "start": "node dist/server.js",
    "typecheck": "tsc -p tsconfig.json --noEmit",
    "test": "vitest run",
    "test:unit": "vitest run test/unit",
    "test:integration": "vitest run test/integration",
    "test:security": "vitest run test/security",
    "test:operational": "vitest run test/operational",
    "test:watch": "vitest",
    "smoke:local": "node scripts/smoke-local.mjs",
    "smoke:preview": "node scripts/smoke-preview.mjs",
    "env:secrets": "node scripts/generate-secrets.mjs",
    "env:secrets:apply": "node scripts/generate-secrets.mjs --apply",
    "prisma:generate": "prisma generate",
    "prisma:push": "prisma db push",
    "check:deps": "node scripts/dependency-check.mjs"
  },
  "dependencies": {
    "@aws-sdk/client-s3": "^3.908.0",
    "@aws-sdk/s3-request-presigner": "^3.908.0",
    "@libsql/client": "^0.15.15",
    "@prisma/adapter-libsql": "^7.6.0",
    "@prisma/client": "^7.6.0",
    "@upstash/redis": "^1.35.6",
    "cookie-parser": "^1.4.7",
    "cors": "^2.8.5",
    "dotenv": "^17.2.3",
    "express": "^5.1.0",
    "helmet": "^8.1.0",
    "jose": "^6.1.0",
    "viem": "^2.38.6",
    "zod": "^4.1.12"
  },
  "devDependencies": {
    "@types/cookie-parser": "^1.4.9",
    "@types/cors": "^2.8.19",
    "@types/express": "^5.0.4",
    "@types/node": "^24.7.2",
    "@types/supertest": "^6.0.3",
    "prisma": "^7.6.0",
    "supertest": "^7.1.4",
    "tsx": "^4.20.6",
    "typescript": "^5.9.3",
    "vitest": "^3.2.4"
  },
  "prisma": {
    "schema": "prisma/schema.prisma"
  }
}
