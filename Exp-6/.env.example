# ============================================================================
# Foundry / Hardhat Core
# ============================================================================

# Deployer private key (WITH 0x prefix, test wallet only)
PRIVATE_KEY=0xyour_wallet_private_key_here

# RPC providers
ALCHEMY_API_KEY=your_alchemy_api_key
ALCHEMY_API_URL_SEPOLIA=https://eth-sepolia.g.alchemy.com/v2/your_alchemy_api_key
INFURA_API_KEY=your_infura_api_key
SEPOLIA_RPC_URL=https://eth-sepolia.g.alchemy.com/v2/your_alchemy_api_key
ANVIL_URL=http://127.0.0.1:8545

# Etherscan verification
ETHERSCAN_API_KEY=your_etherscan_api_key

# ============================================================================
# DVote Role Addresses (DeployDVote.s.sol)
# If left empty, DeployDVote.s.sol defaults each role to deployer.
# ============================================================================
DVOTE_ADMIN=
DVOTE_ECI=
DVOTE_SRO=
DVOTE_RO=
DVOTE_OBSERVER=
DVOTE_KYC_SIGNER=
DVOTE_EMERGENCY=

# ============================================================================
# DVote Shared Runtime Inputs
# ============================================================================
DVOTE_MANAGER_ADDRESS=
DVOTE_ELECTION_ID=
DVOTE_PARENT_ELECTION_ID=

# ============================================================================
# BootstrapElection.s.sol Inputs
# ============================================================================
DVOTE_CONSTITUENCY_ID=
DVOTE_ELECTION_SALT=
DVOTE_REGISTRATION_START=
DVOTE_REGISTRATION_END=
DVOTE_VOTING_START=
DVOTE_VOTING_END=
DVOTE_CANDIDATE_ID=
DVOTE_NOMINATION_HASH=
DVOTE_CANDIDATE_NAME=Candidate One
DVOTE_ADD_NOTA=true

# ============================================================================
# FinalizeElection.s.sol Inputs
# ============================================================================
DVOTE_TIE_SEED=
DVOTE_TIE_SIGNATURE_HEX=
DVOTE_CLOSE_BEFORE_FINALIZE=false

# ============================================================================
# CreateRerunElection.s.sol Inputs
# ============================================================================
DVOTE_CHILD_ELECTION_SALT=
DVOTE_CHILD_REGISTRATION_START=
DVOTE_CHILD_REGISTRATION_END=
DVOTE_CHILD_VOTING_START=
DVOTE_CHILD_VOTING_END=

# ============================================================================
# RotateKycSigner.s.sol Inputs
# ============================================================================
DVOTE_OLD_KYC_SIGNER=
DVOTE_NEW_KYC_SIGNER=

# ============================================================================
# Backend (future integration placeholders)
# ============================================================================
BACKEND_PORT=4000
DATABASE_URL=postgresql://user:pass@localhost:5432/dvote
JWT_SECRET=replace_me
BACKEND_CHAIN_ID=11155111
BACKEND_RPC_URL=
BACKEND_DVOTE_MANAGER_ADDRESS=
BACKEND_EVENT_START_BLOCK=
BACKEND_INDEXER_POLL_MS=4000

# ============================================================================
# Frontend (future integration placeholders)
